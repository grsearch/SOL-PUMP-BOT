# ─── 服务 ─────────────────────────────────────
PORT=3001
DASHBOARD_USER=admin
DASHBOARD_PASS=change_me
# webhook 鉴权 (留空表示不验证, 公网部署务必填)
WEBHOOK_SECRET=

# ─── 钱包 ─────────────────────────────────────
# base58 private key (Phantom export 格式)
TRADER_PRIVATE_KEY=

# ─── Solana RPC ───────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
HELIUS_WSS=wss://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
# LaserStream gRPC endpoint (Helius Business plan)
HELIUS_LASERSTREAM_ENDPOINT=https://laserstream-mainnet-fra.helius-rpc.com
HELIUS_LASERSTREAM_TOKEN=

# ─── Birdeye ──────────────────────────────────
BIRDEYE_API_KEY=
BIRDEYE_BASE=https://public-api.birdeye.so

# ─── Shredstream (法兰克福) ──────────────────
# https://docs.shredstream.com/zh
SHREDSTREAM_ENDPOINT=fra.shredstream.com:9090
SHREDSTREAM_AUTH_TOKEN=
SHREDSTREAM_TIP_LAMPORTS=1000000

# ─── Slipstream (allenhark) ──────────────────
SLIPSTREAM_ENDPOINT=
SLIPSTREAM_API_KEY=

# ─── 策略参数 ─────────────────────────────────
# 买入
BUY_AMOUNT_SOL=1
BUY_PRIORITY_FEE_SOL=0.0005
BUY_SLIPPAGE_BPS=2500
# 普通卖出 (EMA / trailing)
SELL_PRIORITY_FEE_SOL=0.0005
SELL_SLIPPAGE_BPS=3000
# RUG 紧急卖出
RUG_PRIORITY_FEE_SOL=0.005
RUG_TIP_SOL=0.001
RUG_SLIPPAGE_BPS=9000

# K线 / EMA
KLINE_INTERVAL_SEC=15
PRICE_POLL_SEC=1
EMA_FAST=9
EMA_SLOW=20
# 买入后多少根 K 线内禁止 EMA 卖出 (避免噪声)
EMA_WARMUP_BARS=2

# 移动止盈
TRAILING_ACTIVATE_PCT=200
TRAILING_DRAWDOWN_PCT=20

# 监控移除阈值
MONITOR_MIN_FDV=30000
MONITOR_MIN_LP=10000

# RUG 同 slot 检测
RUG_SAME_SLOT_MIN_SELLS=5
RUG_SAME_SLOT_MIN_SOL=5
# priority fee 指纹的容差 (单位: 优先级值,通常是 microLamports per CU)
# 同一机器人批量卖出时, 这个值在每笔 tx 里通常完全一致, 容差给 1000 已足够
RUG_GAS_TOLERANCE_LAMPORTS=1000
# 同一 slot 或相邻 N 个 slot 内的卖单算同一簇
RUG_SLOT_WINDOW=1

# ─── Pump.fun 程序地址 ────────────────────────
PUMP_FUN_PROGRAM=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
PUMP_AMM_PROGRAM=pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA
WSOL_MINT=So11111111111111111111111111111111111111112

# ─── 日志 ─────────────────────────────────────
LOG_LEVEL=info
